# Copie para .env e preencha.
#
# LOCAL: rode `npm run db:start` — ele imprime API_URL e ANON_KEY.
# PRODUÇÃO: Supabase Studio → Project Settings → API.
#
# PUBLIC_* vai para o navegador de propósito (é a anon key, protegida por RLS).
# Nunca coloque a service_role key aqui: ela ignora RLS inteira.
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# Sem prefixo PUBLIC_: só o servidor enxerga. CLAUDE.md §2.11 — a chave nunca vai
# ao cliente. Chave free em https://aistudio.google.com/apikey
GEMINI_API_KEY=
